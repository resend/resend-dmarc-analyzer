# Resend API Key - get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx

# Webhook signing secret - get from Resend webhook settings
RESEND_WEBHOOK_SECRET=whsec_xxxxx

# Email address to receive DMARC report digests
DMARC_RECIPIENT_EMAIL=admin@example.com

# Domain to send emails from (must be verified in Resend)
DMARC_SENDING_DOMAIN=reports.example.com
